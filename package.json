{
  "name": "case-lens-desktop",
  "version": "1.0.0",
  "main": "main.js",
  "description": "Desktop executable application of Case Lens legal crime identifier",
  "author": "Case Lens Team",
  "scripts": {
    "dev:client": "cd client && npm run dev",
    "build:client": "cd client && npm run build",
    "dev:server": "cd server && npm run dev",
    "start": "electron .",
    "package": "npm run build:client && electron-packager . \"Case Lens\" --platform=win32 --arch=x64 --out=dist-desktop --overwrite --ignore=\"client/(src|node_modules|public|tailwind.config.js|postcss.config.js)\" --ignore=\"dist-desktop\" --ignore=\"\\.git\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0"
  },
  "devDependencies": {
    "electron": "^31.1.0",
    "electron-packager": "^17.1.2"
  }
}
