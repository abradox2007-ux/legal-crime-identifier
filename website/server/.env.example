# Groq is free/fast and serves open-source models (Llama 3.3, Mixtral, etc.)
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Model to use. Good defaults on Groq as of mid-2026:
#   llama-3.3-70b-versatile   (best accuracy, recommended)
#   llama-3.1-8b-instant      (fastest/cheapest)
GROQ_MODEL=llama-3.3-70b-versatile

# Swap this without touching code if you want a different country's law.
# See server/prompts/systemPrompt.js
LEGAL_JURISDICTION=India

PORT=5000
CLIENT_ORIGIN=http://localhost:5173
